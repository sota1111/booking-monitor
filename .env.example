# ===================================
# Discord通知設定
# ===================================

# Discord Webhook URL（省略可。未設定時は通知をスキップして動作確認できる）
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_URL

# 追加の通知チャネル（config.json の notification.channels で参照する場合のみ）
# DISCORD_WEBHOOK_URL_SECONDARY=https://discord.com/api/webhooks/YOUR_SECONDARY_WEBHOOK_URL

# ===================================
# アプリケーション設定
# ===================================

# ログレベル（省略可: DEBUG / INFO / WARNING / ERROR）
LOG_LEVEL=INFO

# 設定ファイルのパス（省略可、デフォルト: config.json）
CONFIG_PATH=config.json

# サンプルデータ表示モード（省略可・既定OFF / SOT-1152）。
# 真値（1|true|yes|on）で、起動時にサンプルの監視対象と履歴データを生成し、
# ダッシュボードを実スクレイピングなしで評価できる。本番では未設定のままにする。
# 手動生成は: python scripts/seed_sample_data.py
# SEED_SAMPLE_DATA=1

# ===================================
# ローカルPC収集（方式①: 永続プロファイル）設定
# ===================================
# ブラウザ起動モード: ephemeral（既定・毎チェック新コンテキスト＋storage_state注入）
#   / persistent（永続プロファイルを再利用しログイン状態を保持）
# BOOKING_BROWSER_MODE=persistent
# 永続プロファイルの保存先（persistent モードのみ。既定: ~/.booking-monitor/profile）
# BOOKING_USER_DATA_DIR=~/.booking-monitor/profile
# 真値でブラウザ画面を表示（headful）。初回ログイン/デバッグ用。未設定なら headless
# BOOKING_HEADFUL=1

# ===================================
# GCP / Firestore設定（Cloud Run使用時）
# ===================================

# GCPプロジェクトID（Firestoreを使う場合は必須）
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# FirestoreデータベースID（省略可、デフォルト: (default)）
FIRESTORE_DATABASE_ID=(default)

# Firestoreコレクション名（省略可、デフォルト: monitoring_results）
FIRESTORE_COLLECTION=monitoring_results

# 監視対象（targets）のFirestoreコレクション名（省略可、デフォルト: monitoring_targets）
# SOT-1300: GOOGLE_CLOUD_PROJECT 設定時、Web の登録（POST /targets）と表示、
# およびローカルリサーチ（main.py）の監視対象取得元がこのコレクションになります。
# 未設定（GOOGLE_CLOUD_PROJECT なし）の場合は config.json の targets を使用します。
FIRESTORE_TARGETS_COLLECTION=monitoring_targets

# ===================================
# Firebase Authentication設定
# ===================================
# 案1（サーバサイドREST認証）: サーバ側で accounts:signInWithPassword に使用（必須）
# FIREBASE_WEB_API_KEY が優先され、未設定時は FIREBASE_API_KEY にフォールバックします（どちらか一方でログイン可）。
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
FIREBASE_API_KEY=your-firebase-api-key
# 以下はブラウザ Firebase SDK ログイン廃止により不要（省略可）
# FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_APP_ID=your-firebase-app-id

# 許可するメールアドレス（カンマ区切り）
ALLOWED_USER_EMAILS=your-email@example.com

# セッション署名用シークレット（32文字以上推奨）
AUTH_SECRET=your-random-secret-key-here

# ===================================
# GCP / Cloud Run デプロイ設定
# ===================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-northeast1
CLOUD_RUN_SERVICE_NAME=booking-monitor
ARTIFACT_REGISTRY_REPOSITORY=booking-monitor-registry
IMAGE_NAME=booking-monitor

# ===================================
# （廃止）Cloud Scheduler OIDC 認証設定
# ===================================
# SOT-1300: Web からのリサーチ実行（POST /run）を廃止したため、以下の
# Cloud Scheduler / OIDC 関連の設定は不要になりました。リサーチはローカルの
# `python main.py` から実行します。参考のためコメントで残しています。
# OIDC_AUDIENCE=https://booking-monitor-xxxx.run.app
# SCHEDULER_SA_EMAIL=scheduler-sa@your-gcp-project-id.iam.gserviceaccount.com
# RUN_API_KEY=your-run-api-key
