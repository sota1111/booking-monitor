{
  "targets": [
    {
      "name": "りくろーおじさん リクカフェテラス",
      "url": "https://www.tablecheck.com/shops/rikuro-rikucafeterrace/reserve",
      "interval_seconds": 300,
      "available_keywords": ["空きあり", "予約可能", "○"],
      "unavailable_keywords": ["満席", "空きなし", "予約不可"],
      "notify": true,
      "site_type": "tablecheck",
      "session_state_env": "BOOKING_SESSION_STATE",
      "conditions": {
        "adults": 2,
        "children_under_3": 1,
        "days_of_week": ["Saturday", "Sunday"],
        "date_range": { "start": "2026-07-01", "end": "2026-07-31" },
        "time_range": { "start": "11:00", "end": "15:00", "step_minutes": 15 }
      }
    }
  ],
  "notification": {
    "type": "discord",
    "webhook_url_env": "DISCORD_WEBHOOK_URL",
    "channels": [
      { "type": "discord", "webhook_url_env": "DISCORD_WEBHOOK_URL", "enabled": true },
      { "type": "discord", "webhook_url_env": "DISCORD_WEBHOOK_URL_SECONDARY", "enabled": false }
    ],
    "snooze_until": null
  }
}
